# === Required ===
# Generate with: openssl rand -hex 32
EXA_KEYS_ENCRYPTION_SECRET=replace_with_a_strong_random_secret

# Downstream clients use this token when calling proxied Exa routes. Minimum 16 characters.
EXA_PROXY_TOKENS=replace_with_client_token

# Operators use this token for the Admin Console and /_proxy management APIs. Minimum 16 characters.
EXA_ADMIN_TOKENS=replace_with_admin_token

# === Key seeding ===
# Optional first-start seed. Format: id:key:weight,id:key:weight
# After startup, prefer the Admin Console or POST /_proxy/keys. Values are stored encrypted in SQLite.
EXA_KEYS=

# Optional file seed. Supports plain key, id:key:weight, KEY=value, or ${ENV_VAR} indirection per line.
# EXA_KEYS_FILE=/run/secrets/exa_keys

# === Server ===
# PORT=8787
# HOST=0.0.0.0
# EXA_UPSTREAM_URL=https://api.exa.ai
# EXA_STATE_PATH=./exa-proxy.sqlite
# LOG_LEVEL=info
# EXA_TRUST_PROXY=false

# === Proxy behavior ===
# EXA_SELECTION_STRATEGY=weighted_round_robin
# EXA_ALLOWED_PATHS=/**
# EXA_MAX_ATTEMPTS=3
# EXA_ATTEMPT_TIMEOUT_MS=30000
# EXA_RETRY_BACKOFF_MS=200,600,1500
# EXA_MAX_BODY_BYTES=20971520
# EXA_RESOURCE_AFFINITY=true
# EXA_AFFINITY_RETENTION_DAYS=7
# EXA_UPSTREAM_POOL_CONNECTIONS=128
# EXA_PROXY_RATE_LIMIT_PER_MINUTE=0

# === Circuit breaker and cooldowns ===
# EXA_FAILURE_THRESHOLD=3
# EXA_FAILURE_WINDOW_SECONDS=60
# EXA_COOLDOWN_SECONDS=120
# EXA_RATE_LIMIT_COOLDOWN_SECONDS=300
# EXA_CREDITS_EXHAUSTED_COOLDOWN_SECONDS=600

# === Admin security ===
# Enable when the service is behind HTTPS reverse proxy and EXA_TRUST_PROXY is configured correctly.
# EXA_ADMIN_REQUIRE_HTTPS=false
# EXA_ADMIN_SESSION_TTL_SECONDS=604800
# EXA_ADMIN_LOCKOUT_MAX_FAILURES=5
# EXA_ADMIN_LOCKOUT_WINDOW_SECONDS=300
# EXA_ADMIN_LOCKOUT_SECONDS=900

# Keep disabled in production unless you explicitly need audited raw-key copy in the console.
# EXA_ADMIN_ALLOW_RAW_KEY_DISPLAY=false

# === Observability ===
# EXA_LOG_RETENTION_DAYS=14
# EXA_TREND_WINDOW_HOURS=24
# EXA_ALERT_AVAILABLE_KEY_MIN=1
# EXA_ALERT_FAILURE_RATE_PERCENT=10
# EXA_ALERT_RATE_LIMIT_RATE_PERCENT=20

# === Alert webhook ===
# EXA_ALERT_WEBHOOK_URL=
# EXA_ALERT_WEBHOOK_BEARER_TOKEN=
# EXA_ALERT_WEBHOOK_HMAC_SECRET=
# EXA_ALERT_WEBHOOK_COOLDOWN_SECONDS=300
# EXA_ALERT_WEBHOOK_MAX_ATTEMPTS=1
# EXA_ALERT_WEBHOOK_RETRY_BACKOFF_MS=250
