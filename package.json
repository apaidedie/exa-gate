{
  "name": "exa-reverse-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-admin-ui.mjs",
    "demo:ui": "tsx scripts/demo-ui-server.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.3",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.3",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=22"
  }
}
